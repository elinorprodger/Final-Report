@article{RefWorks:stark1990plastic,
	author={J. W. B. Stark and J. W. P. M. Brekelmans},
	year={1990},
	title={Plastic design of continuous composite slabs},
	journal={Journal of Constructional Steel Research},
	volume={15},
	number={1},
	pages={23-47},
	note={ID: 271633},
	abstract={The present regulations for composite slabs contain simplifications for the design of continuous slabs. Plastic analysis is not allowed unless it can be shown that the plastic hinges have sufficient rotation capacity to allow for the redistribution of moments. Numerical investigations for positive and negative bending and experimental investigation for negative bending have been carried out at Eindhoven Technical University. From these investigations, further conclusions are drawn on the application of plastic analysis for the determination of the bending moments and shear force distribution in a continuous slab and the force distribution at a cross-section. The present rules seem to be contradictory and sometimes superfluous, whereas, on the other hand, some rules are not included and should be inserted.},
	isbn={0143-974X},
